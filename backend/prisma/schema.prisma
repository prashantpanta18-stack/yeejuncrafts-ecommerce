generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model SiteSettings {
  id          Int      @id
  shopAvatar  String?
  bgType      String?
  bgValue     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Product {
  id                Int       @id @default(autoincrement())

  // Identifiers
  slug              String    @unique
  sku               String    @unique

  // Listings data
  name              String
  stockQuantity     Int       @default(0)
  price             Float     @default(0)
  images            String[]  @default([])
  videoUrl          String?
  category          String
  status            String    @default("active")

  // Inventory & shipping
  processingTime    String    @default("")
  shippingType      String    @default("")
  shippingCost      Float     @default(0)

  // Basic stats
  visits            Int       @default(0)
  favorites         Int       @default(0)
  inCart            Int       @default(0)
  revenue           Float     @default(0)
  sales             Int       @default(0)

  // Essential SEO fields
  title             String    @default("")
  description       String    @default("")
  metaTitle         String    @default("")
  metaDesc          String    @default("")
  altText           String    @default("")
  tags              String[]  @default([])

  // Attributes / restrictions
  materials         String[]  @default([])
  excludedCountries String[]  @default([])

  updatedAt         DateTime  @updatedAt
}

model HeaderSettings {
  id                Int      @id @default(1)
  topBarText        String   @default("Welcome to YEEJUNCRAFTS - Handcrafted with Love")
  topBarFontSize    String   @default("12px")
  topBarBgColor     String   @default("#ea580c")
  topBarTextColor   String   @default("#ffffff")
  topBarSpeed       Int      @default(15) // seconds for marquee loop
  logoUrl           String   @default("/logo.png")
  logoWidth         Int      @default(150)
  logoHeight        Int      @default(50)
  navAlignment      String   @default("center") // left, center
  primaryFontFamily String   @default("Inter")
  headerBgColor     String   @default("#ffffff")
  searchBarBgColor  String   @default("#f5f5f4")
  navTextColor      String   @default("#1c1917")
  navHoverColor     String   @default("#ea580c")
  navLinks          Json     @default("[]")
  updatedAt         DateTime @updatedAt
  topBarAlignment   String   @default("center")
  navBgColor        String   @default("transparent")
}

model FooterSettings {
  id              Int      @id @default(1)
  shopDescription String?  @default("Handcrafted with love in Nepal.")
  address         String?  @default("Kathmandu, Nepal")
  phone           String?  @default("+977-9801144324")
  email           String?  @default("yeejuncrafts@gmail.com")
  copyrightText   String?  @default("© 2026 YEEJUNCRAFTS. All rights reserved.")
  columns         Json     @default("[]")
  socialLinks     Json     @default("[]")
  paymentLogos    Json     @default("[]")

  // 🚨 नयाँ थपिएका एडभान्स फिचरहरू
  footerBgColor   String?  @default("#1c1917") // कालो रङ
  textColor       String?  @default("#d6d3d1") // खरानी रङ
  logoUrl         String?  // लोगो अपलोडको लागि
  logoWidth       Int?     @default(150)
  headingFontSize String?  @default("12px")
  contentFontSize String?  @default("14px")

  updatedAt       DateTime @updatedAt
}

model HomePageSettings {
  id                  Int      @id @default(1)
  
  // 1. Hero Section (Slider up to 10 images + Settings)
  heroSlides          Json     @default("[]") // Array of { image, title, subtitle, btnText, btnLink }
  heroSettings        Json     @default("{\"textColor\":\"#ffffff\", \"btnColor\":\"#ea580c\", \"overlayOpacity\":0.5}")
  
  // 2. Trust Badges
  trustBadges         Json     @default("[]") // Array of { icon, title, subtitle }
  trustSettings       Json     @default("{\"bgColor\":\"#fdfbf7\", \"textColor\":\"#1c1917\"}")
  
  // 3. Shop By Category
  categories          Json     @default("[]") // Array of { name, image, link }
  categorySettings    Json     @default("{\"shape\":\"rounded-2xl\", \"btnStyle\":\"outline\"}") // shape: square, rounded-2xl, full (circle)
  
  // 4, 5, 6. Product Grids (New Arrivals, Featured, Masterpieces)
  newArrivalsConfig   Json     @default("{\"show\":true, \"columns\":4, \"limit\":8}")
  featuredProducts    Json     @default("[]") // Array of product SKUs or IDs
  featuredConfig      Json     @default("{\"show\":true, \"columns\":4}")
  masterpieceProducts Json     @default("[]") 
  masterpieceConfig   Json     @default("{\"show\":true, \"columns\":4}")
  
  // 7. Artisan Story (Video or Image Slider)
  storyConfig         Json     @default("{\"type\":\"image\", \"media\":[], \"title\":\"\", \"text1\":\"\", \"text2\":\"\", \"btnText\":\"\", \"btnLink\":\"\"}")
  
  // 8. Blogs
  blogConfig          Json     @default("{\"show\":true, \"columns\":3, \"limit\":3}")

  updatedAt           DateTime @updatedAt
}